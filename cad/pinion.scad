// Pignon pour rack and pinion - La Boîte à Coucou
// Compatible axe SG90 spline cannelé 4.7mm
//
// Paramètres clés :
//   gear_module   : taille des dents (mm) - doit être identique dans rack.scad
//   num_teeth     : nombre de dents - détermine le diamètre primitif
//   thickness     : épaisseur du pignon
//   spline_d      : diamètre de l'alésage spline (légèrement sous 4.7mm pour serrage)

include <MCAD/involute_gears.scad>

// --- Paramètres engrenage ---
gear_module     = 2;           // module standard (taille des dents)
circular_pitch  = gear_module * 180;  // MCAD utilise circular_pitch en "degrés × mm"
num_teeth       = 20;          // diam primitif = 20 × 2 = 40mm -> course = 20π ≈ 63mm
pressure_angle  = 28;          // défaut MCAD, bien pour impression 3D

// --- Géométrie du pignon ---
// gear_thickness  : épaisseur de la couronne dentée
// rim_thickness   : épaisseur du disque (= hub_h pour que le disque soit plein sur toute la hauteur)
// hub_thickness   : hauteur du moyeu central (dépasse pour serrer l'axe)
thickness       = 3.4;         // épaisseur = largeur tige crémaillère (stem_w)
hub_h           = 3.4;         // hauteur totale alignée sur la crémaillère
hub_d           = 10;          // diamètre extérieur du moyeu

