// --- Vis de serrage M2 (optionnel) ---
// Un trou M2 radial permet de bloquer le pignon avec une vis pointeau.
// Mettre à false si tu ne veux pas le perçage.
set_screw       = true;
set_screw_d     = 2.2;         // diamètre trou M2 (légèrement surdimensionné)

// --- Facteur de serrage de l'alésage spline ---
// 1.0 = taille originale (trop lâche à l'impression)
// Réduire pour serrer : chaque -0.05 enlève ~0.1mm sur le rayon
spline_scale    = 0.983;       // compense XY hole compensation +0.03mm du slicer

// =====================================================
// Pignon
// =====================================================

// Rayon primitif = num_teeth * gear_module / 2
pitch_radius = num_teeth * gear_module / 2;  // 20mm
// Rayon de la jante (fond des dents = pitch_radius - dedendum)
rim_radius   = pitch_radius - gear_module * 1.25;  // ~17.5mm

difference() {
    union() {
        // Dents involutes via MCAD - on désactive hub et rim internes
        // en les alignant sur gear_thickness pour éviter les volumes creux
        render()
        gear(
            number_of_teeth = num_teeth,
            circular_pitch  = circular_pitch,
            pressure_angle  = pressure_angle,
            gear_thickness  = hub_h,
            rim_thickness   = hub_h,
            hub_thickness   = hub_h,
            hub_diameter    = hub_d,
            bore_diameter   = 0.1  // alésage géré manuellement via spline_profile
        );

        // Disque plein qui comble le vide entre dents et moyeu
        cylinder(r = rim_radius, h = hub_h, $fn = 80);
    }

    // Alésage axe SG90 - profil spline scalé pour serrage
    translate([0, 0, -0.1])
    linear_extrude(height = hub_h + 0.2)
    scale([spline_scale, spline_scale, 1])
    polygon(spline_profile);

    // Vis de serrage radiale M2
    if (set_screw) {
        translate([hub_d / 2 + 1, 0, hub_h / 2])
        rotate([0, 90, 0])
        cylinder(d = set_screw_d, h = hub_d, $fn = 20);
    }
}
